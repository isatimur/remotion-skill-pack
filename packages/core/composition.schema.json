{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://remotion-skill-pack.vercel.app/composition.schema.json",
  "title": "RemotionComposition",
  "description": "Spec for a Remotion video composition produced by remotion-skill-pack.",
  "type": "object",
  "required": ["meta", "globalTheme", "scenes"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "fps", "width", "height"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "fps": { "type": "integer", "enum": [24, 25, 30, 60], "default": 30 },
        "width": { "type": "integer", "minimum": 320, "default": 1920 },
        "height": { "type": "integer", "minimum": 180, "default": 1080 },
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" }
      }
    },
    "globalTheme": {
      "type": "string",
      "enum": ["book-chapter", "minimal-dark"]
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "durationFrames", "props"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "type": {
            "type": "string",
            "enum": ["title", "concept", "diagram", "quote", "code", "stats", "transition", "outro"]
          },
          "durationFrames": { "type": "integer", "minimum": 1 },
          "props": { "type": "object" }
        }
      }
    }
  }
}
