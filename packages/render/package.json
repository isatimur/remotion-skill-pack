{
  "name": "@remotion-skill-pack/render",
  "version": "0.1.0",
  "description": "CLI + API: convert composition.json to a Remotion TSX project (and optionally render to MP4).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "remotion-skill-pack-render": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@remotion-skill-pack/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "vitest": "^1.5.0"
  }
}
