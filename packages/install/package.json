{
  "name": "@remotion-skill-pack/install",
  "version": "0.1.0",
  "description": "Install any remotion-skill-pack adapter with one command.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "remotion-skill-pack-install": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/adapters && cp -R ../../adapters/. dist/adapters/",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@remotion-skill-pack/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "vitest": "^1.5.0"
  }
}
